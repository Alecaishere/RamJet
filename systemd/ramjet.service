[Unit]
Description=ramjet - process priority daemon
Documentation=https://github.com/Alecaishere/RamJet
After=multi-user.target
Wants=multi-user.target

[Service]
Type=simple
EnvironmentFile=-/etc/default/ramjet
ExecStart=/usr/local/bin/ramjet -d ${RAMJET_CONFIG_DIR} ${RAMJET_OPTS}
Restart=on-failure
RestartSec=5

# Security hardening
ProtectSystem=strict
ProtectHome=true
PrivateTmp=true
NoNewPrivileges=false
ReadWritePaths=/sys/fs/cgroup

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=ramjet

# Resource limits
LimitNICE=true

[Install]
WantedBy=multi-user.target
